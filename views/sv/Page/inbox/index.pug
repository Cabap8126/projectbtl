extends ../../Layout/layout.pug
block main
    h1 Danh sách mon
    .row.mt-4 
        each item in dsgv
            .col-6 
                .card.mb-4 
                    .card-header Lớp : #{item.nameCls} ( #{item.mamh} )
                    .card-body.d-flex.justify-content-between.align-items-center
                        p Tên giảng viên :  #{item.user}
                        if(item.idroom)
                            a(href=`/inbox/${item.idroom}`) Inbox
                        else 
                            a(href=`/dsgv`) Inbox