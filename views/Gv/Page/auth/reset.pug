extends ../../Layout/auth.pug
include ../../mixins/alert.pug
block main
    +alert-success(5000)
    +alert-error(5000)

    .container.my-5 
        .row.justify-content-center 
            .col-8 
                h1(class="text-center" ) Xác Nhận Mật Khẩu Mới
                form(action="/auth/gv/reset" method="POST")
                    div(class="form-group")
                        label(for="password") Mật Khẩu
                        input(type="password" id="password" name="password" class="form-control" required)
                    div(class="form-group")
                        label(for="checkpsw") Xác Nhận Mật Khẩu
                        input(type="password" id="checkpsw" name="checkpsw" class="form-control" required)
                    div(class="form-group")
                        button(type="submit" class="btn btn-primary btn-block") Xác Nhận Mật Khẩu