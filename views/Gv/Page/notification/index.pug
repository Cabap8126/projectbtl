extends ../../Layout/layout.pug
block main 
    h1 Thông báo
    .card.mb-3
        .card-header Danh sách
        .card-body
            .row
                .col-8
                .col-4.text-right
                    a(href=`/gv/notificationcreate/${notification._id}` class="btn btn-outline-success") + Thêm Thông báo
            .row 
                if(notification.tbao.length > 0 )
                    ul
                        each item in notification.tbao
                            li 
                                div(class="tbao")
                                    div #{namegv}
                                    a(href=`/gv/notificationDetail/${notification._id}/${item.id}`) #{item.title}
                                .col-4.d-flex
                                    a(href=`/gv/notificationEdit/${notification._id}/${item.id}` class="btn btn-warning btn-sm") Chỉnh sửa
                                    a(href=`/gv/notificationDeleted/${notification._id}/${item.id}` class="btn btn-danger btn-sm-ml-1") Xóa     
                else
                    p Hiện Tại chưa có thông báo
