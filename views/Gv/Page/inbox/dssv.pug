extends ../../Layout/layout.pug
include ../../mixins/alert.pug
block main
    +alert-success(5000)
    +alert-error(5000)
    h1 Danh sách sinh viên 
    table(class="table table-hover table-sm table-bordered table-dark")
                thead  
                    tr  
                        th STT
                        th Mã Sinh Viên
                        th Tên Sinh Viên 
                tbody 
                    each item,index in dssv.dssv
                        tr
                            td #{index + 1}
                            td #{item.masv}
                            td #{item.tensv}
                            if(item.room_id)
                                td 
                                    a(href=`/inbox/${item.room_id}` class="btn btn-warning btn-sm") Inbox
                            else 
                                td 
                                    a(href=`/newinbox/${dssv.id}/${item.masv}` class="btn btn-warning btn-sm") Inbox 