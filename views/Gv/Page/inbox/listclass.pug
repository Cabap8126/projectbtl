extends ../../Layout/layout.pug
block main
    h1 Danh sách lớp học
    .row.mt-4 
        each item in dsclass
            .col-6 
                .card.mb-4 
                    .card-header Lớp : #{item.nameCls} ( #{item.mamh} )
                    .card-body.d-flex.justify-content-between.align-items-center
                        a(href=`/dssv/${item._id}`) Danh sách sinh viên lớp


